import random

suits = ['Hearts', 'Diamonds', 'Clubs', 'Spades']
ranks = ['2', '3', '4', '5', '6', '7', '8', '9', '10',
         'Jack', 'Queen', 'King', 'Ace']

deck = [(rank, suit) for suit in suits for rank in ranks]

random.shuffle(deck)

print("Cards drawn by user:")
for i in range(5):
    card = deck.pop()
    print(card[0], "of", card[1])
